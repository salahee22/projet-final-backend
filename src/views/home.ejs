<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <style>
      :root {
        color-scheme: light;
        --bg: #f7f5f0;
        --panel: #ffffff;
        --ink: #24221d;
        --muted: #6e675d;
        --line: #ddd4c6;
        --accent: #247a69;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        background: var(--bg);
        color: var(--ink);
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      }

      main {
        width: min(960px, calc(100% - 32px));
        margin: 0 auto;
        padding: 48px 0;
      }

      h1 {
        margin: 0 0 10px;
        font-size: clamp(2rem, 5vw, 4rem);
        line-height: 1;
      }

      p {
        max-width: 760px;
        margin: 0 0 24px;
        color: var(--muted);
        line-height: 1.6;
      }

      table {
        width: 100%;
        border-collapse: collapse;
        overflow: hidden;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--panel);
      }

      th,
      td {
        padding: 13px 14px;
        border-bottom: 1px solid var(--line);
        text-align: left;
        vertical-align: top;
      }

      th {
        color: var(--muted);
        font-size: 0.8rem;
        text-transform: uppercase;
      }

      tr:last-child td {
        border-bottom: 0;
      }

      code {
        color: var(--accent);
        font-weight: 700;
      }
    </style>
  </head>
  <body>
    <main>
      <h1><%= title %></h1>
      <p>
        Express, EJS, MongoDB, validators, middleware, routes, config, and utils are wired.
        The API base is <code><%= baseUrl %></code>.
      </p>

      <table aria-label="Available backend endpoints">
        <thead>
          <tr>
            <th>Method</th>
            <th>Path</th>
            <th>Description</th>
          </tr>
        </thead>
        <tbody>
          <% endpoints.forEach((endpoint) => { %>
            <tr>
              <td><code><%= endpoint.method %></code></td>
              <td><code><%= endpoint.path %></code></td>
              <td><%= endpoint.description %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </main>
  </body>
</html>
